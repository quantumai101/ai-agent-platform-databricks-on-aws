# ==========================================
# AI Agent Platform - Environment Variables
# ==========================================

# Anthropic API
ANTHROPIC_API_KEY=sk-ant-xxxxx

# AWS Configuration
AWS_ACCOUNT_ID=123456789012
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIAXXXXX
AWS_SECRET_ACCESS_KEY=xxxxx

# AWS Services
ECR_REGISTRY=123456789.dkr.ecr.us-east-1.amazonaws.com
EKS_CLUSTER_NAME=ai-agents-cluster
S3_BUCKET=ai-agents-datalake

# Databricks
DATABRICKS_HOST=https://your-workspace.cloud.databricks.com
DATABRICKS_TOKEN=dapi-xxxxx

# Database
DATABASE_URL=postgresql://user:pass@localhost:5432/aiagents
REDIS_URL=redis://localhost:6379

# MLflow
MLFLOW_TRACKING_URI=databricks
MLFLOW_EXPERIMENT_NAME=/Shared/ai-agents

# Monitoring
PROMETHEUS_URL=http://localhost:9090
GRAFANA_URL=http://localhost:3000

# Security
JWT_SECRET=your-secret-key-here
ENCRYPTION_KEY=your-encryption-key-here
